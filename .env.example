# Server
# App Platform injects PORT in production; keep this for local development.
HOST=0.0.0.0
PORT=4000
APP_NAME=kult-browser-backend
CORS_ORIGINS=https://your-frontend-domain.example

# Auth / JWT
JWT_SECRET=change-me-before-production
JWT_EXPIRATION_DAYS=7

# Shared browser access codes
# Generate each hash with:
#   npm run hash:access-code -- "your-shared-code"
# Supported formats: scrypt$N$r$p$salt$key (recommended), sha256:<hex>
ACCESS_CODE_SESSION_EXPIRATION_DAYS=7
ACCESS_CODE_TIER_1_HASH=
ACCESS_CODE_TIER_2_HASH=
ACCESS_CODE_TIER_3_HASH=
ACCESS_CODE_TIER_4_HASH=
ACCESS_CODE_TIER_5_HASH=

# SIWE (Sign-In with Ethereum — EIP-4361)
# Shown in the sign message. Override to match your actual domain.
SIWE_DOMAIN=app.kultgames.io
SIWE_URI=https://app.kultgames.io
SIWE_CHAIN_ID=1

# Logging
LOG_LEVEL=info
LOG_FORMAT=pretty
LOG_FILE_INFO=false
LOG_TARGET=true

# MongoDB
MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=kult_browser
MONGO_CONN_RETRIES=5

# MongoDB collections
GAMES_COLL=kultbrowser_games
CONTENT_COLL=kultbrowser_content_configs
CAMPAIGNS_COLL=kultbrowser_campaigns
CHATBOT_COLL=kultbrowser_chatbot_knowledge
PLAYERS_COLL=store_players
GLOBAL_LEADERBOARD_COLL=global_leaderboards
GAME_LEADERBOARD_CONFIG_COLL=store_games_leaderboards
AI_MODELS_COLL=ai_models
SHARED_POSTS_COLL=shared_posts
ONCHAIN_ACTIVITY_JOBS_COLL=onchain_activity_jobs
PLAYER_NONCES_COLL=player_nonces

# Valkey
VALKEY_URL=redis://127.0.0.1:6379

# DigitalOcean Spaces (Moments)
DO_SPACES_KEY=your-spaces-access-key
DO_SPACES_SECRET=your-spaces-secret-key
DO_SPACES_ENDPOINT=https://sfo3.digitaloceanspaces.com
DO_SPACES_REGION=sfo3
MOMENTS_DO_SPACES_BUCKET=your-bucket
MOMENTS_DOWNLOAD_TMP_DIR=/tmp/moments
MOMENTS_DO_SPACES_PRESIGNED_EXPIRATION=300
MOMENTS_UPLOAD_PATH=moments

# Bright Data Web Scraper API
BD_API_KEY=your-bright-data-api-key
BD_BASE_URL=https://api.brightdata.com
BD_TRIGGER_PATH=/datasets/v3/trigger
BD_PROGRESS_PATH=/datasets/v3/progress
BD_SNAPSHOT_PATH=/datasets/v3/snapshot
BD_POLL_INTERVAL=10
BD_POLL_TIMEOUT=180
BD_DATASET_TWITTER=gd_lwxkxvnf1cynvib9co
BD_DATASET_INSTAGRAM=gd_lk5ns7kz21pck8jpis
BD_DATASET_TIKTOK=gd_lu702nij2f790tmv9h
BD_DATASET_FACEBOOK=gd_lyclm1571iy3mv57zw
BD_DATASET_REDDIT=gd_lvz8ah06191smkebj4
BD_DATASET_LINKEDIN=gd_lyy3tktm25m4avu764
BD_DATASET_PINTEREST=gd_lk0sjs4d21kdr7cnlv

# Post-scrape worker
SCRAPE_MIN_AGE_HOURS=24
SCRAPE_MAX_RETRIES=3
SCRAPE_POLL_TIMEOUT_SECS=5
SCRAPE_REQUEUE_SLEEP_SECS=60
SCRAPE_VALIDATION_TERMS=kult,kult moments,0g,web3 gaming

# 0G gateway/explorer URL templates (optional — used in moment responses)
# Example: ZG_GATEWAY_URL=https://indexer.0g.ai/file/{hash}
ZG_GATEWAY_URL=
# Example: ZG_EXPLORER_TX_URL=https://chainscan-galileo.0g.ai/tx/{txHash}
ZG_EXPLORER_TX_URL=

# 0G DA Disperser (real Data Availability — optional but required for DA proof events)
# The gRPC-gateway HTTP wrapper URL for the 0G DA disperser service
# Example: ZG_DA_DISPERSER_URL=https://da-disperser.0g.ai
ZG_DA_DISPERSER_URL=

# 0G Compute (AI analysis — optional, enables moment.ai_processed DA events)
# Step 1: 0g-compute-cli inference list-providers  → pick a provider address
# Step 2: 0g-compute-cli inference get-secret --provider <ADDRESS>  → get app-sk-* key
ZG_COMPUTE_PROVIDER_URL=
ZG_COMPUTE_API_KEY=
ZG_COMPUTE_MODEL=gpt-4o-mini

# Moment share previews (Open Graph for X/Facebook/WhatsApp/etc.)
# SPA origin — where browsers land after opening a preview link
PUBLIC_APP_URL=https://your-frontend-domain.example
SHARE_BASE_URL=https://your-backend-domain.example
# Optional fallback OG image when a video moment has no thumbnail
SHARE_DEFAULT_OG_IMAGE=https://your-cdn.example/kult-moments-og.jpg
SHARE_SITE_NAME=Kult Moments

# Onchain activity recorder (Moments)
ONCHAIN_ENABLED=false
ONCHAIN_RPC_URL=https://evmrpc.0g.ai/
ONCHAIN_CHAIN_ID=16661
ONCHAIN_ACTIVITY_CONTRACT=
ONCHAIN_RELAYER_PRIVATE_KEY=
ONCHAIN_CONFIRMATIONS=1
ONCHAIN_POLL_INTERVAL_SECS=5
ONCHAIN_MAX_RETRIES=5
